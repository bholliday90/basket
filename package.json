{
  "name": "basket",
  "version": "1.0.0",
  "description": "Basket - Grocery Price Comparison App",
  "scripts": {
    "start": "NODE_ENV=production node --max-old-space-size=512 backend/index.js",
    "backend": "node --max-old-space-size=512 backend/index.js",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "cd frontend && npm install && npm run build && mkdir -p ../dist && cp -r dist/. ../dist/",
    "init-db": "node backend/init-db.js"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "cheerio": "^1.2.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  }
}
